# Claude API (필수)
ANTHROPIC_API_KEY=

# OpenAI GPT Image — 이미지 생성 (필수)
OPENAI_API_KEY=

# Tavily — 웹 서치 (필수: 레퍼런스/소비자 리서치 에이전트)
TAVILY_API_KEY=

# Slack — 결과물 전송 (필수)
# Slack 앱 생성 → Incoming Webhooks → Webhook URL 복사
SLACK_WEBHOOK_URL=

# Notion — 기록 저장 (필수)
# Notion 인테그레이션 생성 → Internal Integration Token 복사
NOTION_TOKEN=
# 기록할 데이터베이스 ID (Notion DB URL에서 추출)
NOTION_DATABASE_ID=

# Stability AI SDXL — 이미지 생성 폴백 (선택)
# STABILITY_API_KEY=

# ── 정산팀 — Cafe24 ──────────────────────────────────────
# 브랜드가 하나: CAFE24_ADMIN_ID / CAFE24_PASSWORD
# 브랜드가 여럿: CAFE24_{브랜드대문자}_ADMIN_ID / CAFE24_{브랜드대문자}_PASSWORD
# 예) 브랜드=brainology → CAFE24_BRAINOLOGY_ADMIN_ID
CAFE24_ADMIN_ID=
CAFE24_PASSWORD=
# CAFE24_BRAINOLOGY_ADMIN_ID=
# CAFE24_BRAINOLOGY_PASSWORD=

# Cafe24 다운로드 저장 경로 (기본값 사용 시 주석 유지)
# CAFE24_DOWNLOAD_DIR=teams/settlement/downloads

# Cafe24 브라우저 헤드리스 모드 (false 설정 시 브라우저 창 표시)
# CAFE24_HEADLESS=true

# ── 상품 기획팀 — 네이버 검색광고 API (선택) ─────────────
# 월간 검색수(절대값) 조회 — 없으면 WebSearch 기반 추정치로 대체됨
# 발급: https://searchad.naver.com → 우측 상단 계정 → [설정] → [API 관리]
NAVER_AD_API_KEY=
NAVER_AD_SECRET_KEY=
NAVER_AD_CUSTOMER_ID=
